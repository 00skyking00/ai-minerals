# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
build/
dist/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# uv
.uv/
uv.lock

# Jupyter / Quarto
.ipynb_checkpoints/
*.ipynb_meta
_site/
.quarto/
_freeze/

# Data — large files belong in data/raw/ but stay out of git
# If a specific small file *should* be committed, force-add with `git add -f`
data/raw/**
data/derived/**
!data/raw/.gitkeep
!data/derived/.gitkeep
!data/raw/README.md
!data/derived/README.md

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp

# Claude Code tool state
.claude/

# Secrets (belt and suspenders — never expected in this repo)
.env
.env.*
*.pem
*.key
