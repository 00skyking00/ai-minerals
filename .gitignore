# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
build/
dist/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# uv
.uv/
uv.lock

# Jupyter / Quarto
.ipynb_checkpoints/
*.ipynb_meta
_site/
_site_internal/
.quarto/
_freeze/

# Pre-prod-push snapshots (last 3 retained by scripts/snapshot_prod.sh)
/snapshots/

# Quarto per-notebook render artifacts (regenerated on `quarto render`)
**/*_files/
/index_files/

# osmnx working cache (regeneratable from Overpass; not source)
/.osm_cache/

# portfolio/data is a symlink to ../data so the Quarto site at portfolio/
# can resolve notebook qmds' relative ../../data/... refs without pulling
# data/ into the project tree. Not source — don't track the symlink.
/portfolio/data

# Third-party repositories cloned for reference / reproduction work
third_party/

# Data — large files belong in data/raw/ but stay out of git
# If a specific small file *should* be committed, force-add with `git add -f`
data/raw/**
data/derived/**
!data/raw/.gitkeep
!data/derived/.gitkeep
!data/raw/README.md
!data/derived/README.md

# OS
.DS_Store
Thumbs.db
# Windows ADS metadata that WSL exposes as a separate file
*:Zone.Identifier

# Editors
.vscode/
.idea/
*.swp

# Claude Code tool state
.claude/

# Secrets (belt and suspenders — never expected in this repo)
.env
.env.*
*.pem
*.key

/.quarto/
**/*.quarto_ipynb*

# Quarto installer (downloaded to repo root, not a repo artifact)
/quarto-*.deb
outreach/

**/*.quarto_ipynb

# Vendored third-party binaries (rebuilt via scripts/build_pomdpsol.sh).
# The build script + source URL are tracked; the build tree + binary are not.
/vendor/
