# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
build/
dist/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# uv
.uv/
uv.lock

# Jupyter / Quarto
.ipynb_checkpoints/
*.ipynb_meta
_site/
_site_internal/
.quarto/
_freeze/

# Third-party repositories cloned for reference / reproduction work
third_party/

# Data — large files belong in data/raw/ but stay out of git
# If a specific small file *should* be committed, force-add with `git add -f`
data/raw/**
data/derived/**
!data/raw/.gitkeep
!data/derived/.gitkeep
!data/raw/README.md
!data/derived/README.md

# gldbg — embedded mining-claim recon tool. The Python source under gldbg/
# is tracked; runtime artifacts and the FTP env are not. data/ml/ (~16 MB
# of ML rasters + rationale parquet) IS tracked because it's the deployable
# artifact, even though it's regenerable from the ai-minerals motherlode
# scripts.
gldbg/.venv/
gldbg/.cache/
gldbg/output/
gldbg/.env
gldbg/goldbug.egg-info/

# OS
.DS_Store
Thumbs.db
# Windows ADS metadata that WSL exposes as a separate file
*:Zone.Identifier

# Editors
.vscode/
.idea/
*.swp

# Claude Code tool state
.claude/

# Secrets (belt and suspenders — never expected in this repo)
.env
.env.*
*.pem
*.key

/.quarto/
**/*.quarto_ipynb*

# Quarto installer (downloaded to repo root, not a repo artifact)
/quarto-*.deb
outreach/

**/*.quarto_ipynb
